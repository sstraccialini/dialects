            </M>
            <TRANSL>AUX.PRF(1)</TRANSL>
        </W>
        <W>
            <M class="CL">
                <FORM>ˈfuːrni</FORM>
                <TRANSL>end.PFV</TRANSL>
            </M>
            <M>
                <FORM>ja</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ˈprv</FORM>
                <TRANSL>first</TRANSL>
            </M>
            <M>
                <FORM>i</FORM>
                <TRANSL>ACC.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈpuːt</FORM>
                <TRANSL>way.ACC.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Als er mit der ersten Runde fertig war,</TRANSL>
        <TRANSL xml:lang="en">When he (had) finished the first round,</TRANSL>
    </S>
    <S id="s15">
        <AUDIO start="47.0279" end="48.8898"/>
        <FORM>je sa vrnija van.</FORM>
        <TRANSL xml:lang="it">tornò in campagna.</TRANSL>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>sa=</FORM>
                <TRANSL>REFL</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>vɛ́rni</FORM>
                <TRANSL>return.PFV</TRANSL>
            </M>
            <M>
                <FORM>ja</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ˈvan</FORM>
                <TRANSL>in.the.country</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">kehrte er aufs Feld zurück.</TRANSL>
        <TRANSL xml:lang="en">he went back to the field.</TRANSL>
    </S>
    <S id="s16">
        <AUDIO start="49.0700" end="51.4124"/>
        <FORM>Je jopa napunija baundze</FORM>
        <TRANSL xml:lang="it">Riempì di nuovo la *bigonce*</TRANSL>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>jópa</FORM>
                <TRANSL>again</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ná</FORM>
                <TRANSL>PFV</TRANSL>
            </M>
            <M>
                <FORM>puni</FORM>
                <TRANSL>fill</TRANSL>
            </M>
            <M>
                <FORM>ja</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>báuːndz</FORM>
                <TRANSL>barrel</TRANSL>
            </M>
            <M>
                <FORM>e</FORM>
                <TRANSL>ACC.PL.F</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Er füllte wieder die Bütten,</TRANSL>
        <TRANSL xml:lang="en">He filled up the barrels again,</TRANSL>
    </S>
    <S id="s17">
        <AUDIO start="51.5325" end="53.6947"/>
        <FORM>za ponit još grozja doma.</FORM>
        <TRANSL xml:lang="it">per portare ancora uva a casa.</TRANSL>
        <W>
            <M>
                <FORM>za</FORM>
                <TRANSL>for</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>póni</FORM>
                <TRANSL>take.PFV</TRANSL>
            </M>
            <M>
                <FORM>t</FORM>
                <TRANSL>INF</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>joʃ</FORM>
                <TRANSL>still</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈgroːzj</FORM>
                <TRANSL>grape</TRANSL>
            </M>
            <M>
                <FORM>ḁ</FORM>
                <TRANSL>GEN.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈdom</FORM>
                <TRANSL>home</TRANSL>
            </M>
            <M>
                <FORM>ḁ</FORM>
                <TRANSL>GEN.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">um noch weitere Trauben heimzubringen.</TRANSL>
        <TRANSL xml:lang="en">in order to bring still more grapes home.</TRANSL>
    </S>
    <S id="s18">
        <AUDIO start="53.6947" end="55.9771"/>
        <FORM>Ma tovar sa neča mobaša.</FORM>
        <TRANSL xml:lang="it">*Ma* l’asino non si voleva *muovere*.</TRANSL>
        <W>
            <M class="CL">
                <FORM>ma</FORM>
                <TRANSL>but</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>tóvar</FORM>
                <TRANSL>donkey.NOM.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>sa=</FORM>
                <TRANSL>REFL</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈne</FORM>
                <TRANSL>NEG</TRANSL>
            </M>
            <M>
                <FORM>tʃ</FORM>
                <TRANSL>want</TRANSL>
            </M>
            <M>
                <FORM>a</FORM>
                <TRANSL>PRS.3SG</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>ˈmoːb</FORM>
                <TRANSL>move.IPFV</TRANSL>
            </M>
            <M>
                <FORM>aʃ</FORM>
                <TRANSL>IPRF</TRANSL>
            </M>
            <M>
                <FORM>a</FORM>
                <TRANSL>3SG</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Aber der Esel wollte sich nicht bewegen.</TRANSL>
        <TRANSL xml:lang="en">But the donkey didn’t want to move.</TRANSL>
    </S>
    <S id="s19">
        <AUDIO start="56.2173" end="59.5207"/>
        <FORM>Tiraj oglav nu votu, tiraj dvi, tiraj tri,</FORM>
        <TRANSL xml:lang="it">*Tira* la briglia una *volta, *tira* due, *tira* tre,</TRANSL>
        <W>
            <M class="CL">
                <FORM>tír</FORM>
                <TRANSL>pull.PFV</TRANSL>
            </M>
            <M class="CL">
                <FORM>aːj</FORM>
                <TRANSL>IMP.2SG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈoglav</FORM>
                <TRANSL>rein.ACC.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>n</FORM>
                <TRANSL>one</TRANSL>
            </M>
            <M>
                <FORM>u=</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>vóːt</FORM>
                <TRANSL>time</TRANSL>
            </M>
            <M>
                <FORM>u̥</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>tír</FORM>
                <TRANSL>pull.PFV</TRANSL>
            </M>
            <M class="CL">
                <FORM>aːj</FORM>
                <TRANSL>IMP.2SG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈdwi</FORM>
                <TRANSL>two.F</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>tír</FORM>
                <TRANSL>pull.PFV</TRANSL>
            </M>
            <M class="CL">
                <FORM>aːj</FORM>
                <TRANSL>IMP.2SG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈtri</FORM>
                <TRANSL>three</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Zieh den Zügel einmal, zieh zwei, zieh drei, (er zog…)</TRANSL>
        <TRANSL xml:lang="en">Pull (=he pulled) the reins once, pull twice, pull three times,</TRANSL>
    </S>
    <S id="s20">
        <AUDIO start="59.5207" end="61.0822"/>
        <FORM>naza je sa štufa</FORM>
        <TRANSL xml:lang="it">alla fine si *stufò*</TRANSL>
        <W>
            <M>
                <FORM>náza</FORM>
                <TRANSL>finally</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>sa=</FORM>
                <TRANSL>REFL</TRANSL>
            </M>
        </W>
        <W>
            <TRANSL>PRF(1)</TRANSL>
            <M class="CL">
                <FORM>ʃtúfa</FORM>
                <TRANSL>get.fed.up.PFV.PTCP.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">schließlich wurde er es leid,</TRANSL>
        <TRANSL xml:lang="en">finally he was annoyed,</TRANSL>
    </S>
    <S id="s21">
        <AUDIO start="61.2024" end="63.3045"/>
        <FORM>e je seta tovaru nu šaku,</FORM>
        <TRANSL xml:lang="it">*e assestò* all’asino un pugno,</TRANSL>
        <W>
            <M class="CL">
                <FORM>e</FORM>
                <TRANSL>and</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(2)</TRANSL>
        </W>
        <W>
            <M class="CL">
                <FORM>séta</FORM>
                <TRANSL>throw.PFV.PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>tóvar</FORM>
                <TRANSL>donkey</TRANSL>
            </M>
            <M>
                <FORM>u</FORM>
                <TRANSL>DAT.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>n</FORM>
                <TRANSL>ART.INDF</TRANSL>
            </M>
            <M>
                <FORM>u=</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈʃak</FORM>
                <TRANSL>fist</TRANSL>
            </M>
            <M>
                <FORM>u</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">und versetzte dem Esel einen Faustschlag,</TRANSL>
        <TRANSL xml:lang="en">and punched the donkey with his fist,</TRANSL>
    </S>
    <S id="s22">
        <AUDIO start="63.4246" end="65.5868"/>
        <FORM>jušt u glavu, ma fermu!</FORM>
        <TRANSL xml:lang="it">*proprio* in testa, *ma forte*!</TRANSL>
        <W>
            <M class="CL">
                <FORM>ˈjuʃt</FORM>
                <TRANSL>exactly</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈu</FORM>
                <TRANSL>in</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>=glav</FORM>
                <TRANSL>head</TRANSL>
            </M>
            <M>
                <FORM>u</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>ma</FORM>
                <TRANSL>but</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>ˈfeːrm</FORM>
                <TRANSL>strong</TRANSL>
            </M>
            <M>
                <FORM>u</FORM>
                <TRANSL>ACC.SG.F</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">genau auf den Kopf, aber fest!</TRANSL>
        <TRANSL xml:lang="en">right on the head, and hard!</TRANSL>
    </S>
    <S id="s23">
        <AUDIO start="66.0073" end="68.2295"/>
        <FORM>Tovar je pa pozjamu mrtav.</FORM>
        <TRANSL xml:lang="it">L’asino cadde per terra morto.</TRANSL>
        <W>
            <M>
                <FORM>tóvar</FORM>
                <TRANSL>donkey.NOM.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ˈpa</FORM>
                <TRANSL>fall.PFV.PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ˈpozjamu</FORM>
                <TRANSL>on.the.earth</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>mŕtav</FORM>
                <TRANSL>dead.NOM.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Der Esel fiel tot zu Boden.</TRANSL>
        <TRANSL xml:lang="en">The donkey fell to the ground dead.</TRANSL>
    </S>
    <S id="s24">
        <AUDIO start="68.3497" end="71.2326"/>
        <FORM>On je ga gleda e je mu reka:</FORM>
        <TRANSL xml:lang="it">Egli lo guardò *e* gli disse:</TRANSL>
        <W>
            <M>
                <FORM>ˈoːn</FORM>
                <TRANSL>he.NOM</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ga=</FORM>
                <TRANSL>he.ACC</TRANSL>
            </M>
        </W>
        <W>
            <TRANSL>PRF(1)</TRANSL>
            <M>
                <FORM>ˈgleda</FORM>
                <TRANSL>look.PTCP.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>e</FORM>
                <TRANSL>and</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>mu=</FORM>
                <TRANSL>he.DAT</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈrek</FORM>
                <TRANSL>say.PFV</TRANSL>
            </M>
            <M>
                <FORM>a</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(2)</TRANSL>
        </W>
        <TRANSL xml:lang="de">Es schaute ihn an und sagte zu ihm:</TRANSL>
        <TRANSL xml:lang="en">He looked at it and said to it:</TRANSL>
    </S>
    <S id="s25">
        <AUDIO start="71.1725" end="73.2146"/>
        <FORM>«S moždani ma moraš zaorat,</FORM>
        <TRANSL xml:lang="it">“Con il cervello mi puoi fregare,</TRANSL>
        <W>
            <M>
                <FORM>s=</FORM>
                <TRANSL>with</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>móʒd</FORM>
                <TRANSL>brain</TRANSL>
            </M>
            <M>
                <FORM>aːni</FORM>
                <TRANSL>INS.PL.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ma=</FORM>
                <TRANSL>I.ACC</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈmor</FORM>
                <TRANSL>can</TRANSL>
            </M>
            <M>
                <FORM>a</FORM>
                <TRANSL>PRS</TRANSL>
            </M>
            <M>
                <FORM>ʃ</FORM>
                <TRANSL>2SG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈza</FORM>
                <TRANSL>PFV</TRANSL>
            </M>
            <M>
                <FORM>ora</FORM>
                <TRANSL>cheat</TRANSL>
            </M>
            <M>
                <FORM>t</FORM>
                <TRANSL>INF</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">"Mit dem Hirn kannst du mich verarschen,</TRANSL>
        <TRANSL xml:lang="en">“With your brain you can fool me,</TRANSL>
    </S>
    <S id="s26">
        <AUDIO start="73.2146" end="74.8363"/>
        <FORM>ma ne s forcom!»</FORM>
        <TRANSL xml:lang="it">*ma* non con la *forza*!”</TRANSL>
        <W>
            <M class="CL">
                <FORM>ˈma</FORM>
                <TRANSL>but</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈne</FORM>
                <TRANSL>NEG</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>s=</FORM>
                <TRANSL>with</TRANSL>
            </M>
        </W>
        <W>
            <M class="CL">
                <FORM>ˈfo:rts</FORM>
                <TRANSL>power</TRANSL>
            </M>
            <M>
                <FORM>om</FORM>
                <TRANSL>INS.SG.F</TRANSL>
            </M>
        </W>
        <W/>
        <TRANSL xml:lang="de">aber nicht mit der Kraft!"</TRANSL>
        <TRANSL xml:lang="en">but not with the power!”</TRANSL>
    </S>
   
</TEXT>