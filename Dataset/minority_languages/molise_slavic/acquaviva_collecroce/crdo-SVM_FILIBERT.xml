                <FORM>ja</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(1)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ˈgroːzʎ</FORM>
                <TRANSL>grape</TRANSL>
            </M>
            <M>
                <FORM>a</FORM>
                <TRANSL>GEN.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">Er füllte sie mit Trauben,</TRANSL>
        <TRANSL xml:lang="en">He filled them with grapes,</TRANSL>
    </S>
    <S id="s12">
        <AUDIO start="40.6614" end="43.0639"/>
        <FORM>e pa je ponija ovi grozlja doma,</FORM>
        <TRANSL xml:lang="it">*e* poi portò quest’uva a casa,</TRANSL>
        <W>
            <M class="CL">
                <FORM>e</FORM>
                <TRANSL>and</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>pa</FORM>
                <TRANSL>then</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>je=</FORM>
                <TRANSL>be.PRS.3SG</TRANSL>
            </M>
            <TRANSL>AUX.PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>póni</FORM>
                <TRANSL>take.PFV</TRANSL>
            </M>
            <M>
                <FORM>ja</FORM>
                <TRANSL>PTCP.SG.M</TRANSL>
            </M>
            <TRANSL>PRF(2)</TRANSL>
        </W>
        <W>
            <M>
                <FORM>ov</FORM>
                <TRANSL>DEM.PROX</TRANSL>
            </M>
            <M>
                <FORM>i</FORM>
                <TRANSL>ACC.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈgroːzʎ</FORM>
                <TRANSL>grape</TRANSL>
            </M>
            <M>
                <FORM>ḁ</FORM>
                <TRANSL>ACC.SG.M</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>ˈdom</FORM>
                <TRANSL>home</TRANSL>
            </M>
            <M>
                <FORM>ḁ</FORM>
                <TRANSL>GEN.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">und dann brachte er diese Trauben nach Hause,</TRANSL>
        <TRANSL xml:lang="en">and then he brought these grapes home,</TRANSL>
    </S>
    <S id="s13">
        <AUDIO start="43.0639" end="44.2651"/>
        <FORM>semaj s tovarom.</FORM>
        <TRANSL xml:lang="it">*sempre* coll’asino.</TRANSL>
        <W>
            <M class="CL">
                <FORM>sémaːj</FORM>
                <TRANSL>always</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>s</FORM>
                <TRANSL>with</TRANSL>
            </M>
        </W>
        <W>
            <M>
                <FORM>tóvar</FORM>
                <TRANSL>donkey</TRANSL>
            </M>
            <M>
                <FORM>om</FORM>
                <TRANSL>INS.SG.M</TRANSL>
            </M>
        </W>
        <TRANSL xml:lang="de">immer mit dem Esel.</TRANSL>
        <TRANSL xml:lang="en">always by donkey.</TRANSL>
    </S>
    <S id="s14">
        <AUDIO start="44.8657" end="47.1480"/>
        <FORM>Kada je furnija prvi put,</FORM>
        <TRANSL xml:lang="it">Quando *finì* il primo viaggio,</TRANSL>
        <W>
            <M>
