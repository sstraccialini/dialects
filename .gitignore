# Python virtualenvs
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Per-user SLURM paths (each group member edits their own copy on HPC).
slurm/tools/env.local.sh

# SLURM job logs
slurm/logs/*
!slurm/logs/.gitkeep

# Wikipedia dump intermediates and bz2 archives (heavy)
Dataset/wiki/*_texts/
Dataset/wiki/*.xml.bz2

# Method-specific binary artefacts (too large for GitHub).
# Vectors / models live under method_outputs/; evaluation outputs are kept.
analysis/**/method_outputs/models/
analysis/**/method_outputs/**/*.bin
analysis/**/method_outputs/**/*.bin.*
analysis/**/method_outputs/**/*.safetensors
analysis/**/method_outputs/**/*.npy
analysis/**/method_outputs/**/sentence_vectors.npz
analysis/**/method_outputs/**/combined_corpus.csv
