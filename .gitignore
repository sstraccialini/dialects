# Python virtualenvs
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo

# Editor / IDE / OS metadata
.DS_Store
.vscode/
.idea/
*.swp

# Hugging Face / Transformers download cache (used by deep-model runs)
.cache/

# ---------------------------------------------------------------------------
# Data — Wikipedia
# ---------------------------------------------------------------------------
# The Wiki dump intermediates (~50 GB) are never committed. The pipeline at
# Dataset/wiki/PIPELINE.md regenerates them from public sources.
Dataset/wiki/*_texts/
Dataset/wiki/*.xml.bz2
Dataset/wiki/_cache/

# Only the 100k-sampled <code>.csv files are tracked. The full corpora
# (`<code>_complete.csv`), per-article metadata (`<code>_meta.csv`) and
# corpus stats (`<code>_stats.json`) stay local.
Dataset/wiki/normalized/**/*_complete.csv
Dataset/wiki/normalized/**/*_meta.csv
Dataset/wiki/normalized/**/*_stats.json
Dataset/wiki/not_normalized/**/*_complete.csv
Dataset/wiki/not_normalized/**/*_meta.csv
Dataset/wiki/not_normalized/**/*_stats.json

# Exploratory side-varieties (lld, nap, pms) not in the 17-variety registry.
Dataset/wiki/normalized/others_dialects/
Dataset/wiki/not_normalized/others_dialects/

# ---------------------------------------------------------------------------
# Method outputs
# ---------------------------------------------------------------------------
# Vectors and trained models live under method_outputs/ and are reproducible
# from the run.py scripts. Light evaluation_results/ artefacts (distances.csv,
# silhouette.csv, plots, ...) stay tracked.
analysis/**/method_outputs/models/
analysis/**/method_outputs/**/*.bin
analysis/**/method_outputs/**/*.bin.*
analysis/**/method_outputs/**/*.safetensors
analysis/**/method_outputs/**/*.npy
analysis/**/method_outputs/**/sentence_vectors.npz
analysis/**/method_outputs/**/combined_corpus.csv
analysis/**/method_outputs/**/variety_vectors.csv
analysis/**/method_outputs/**/variety_vectors.npz

# Fine-tuned encoder checkpoints
analysis/**/models/

# Run logs piped to local files
*_run.log
