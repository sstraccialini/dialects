#!/bin/bash
#SBATCH --job-name=ltp_08_wiki_subword_fasttext
#SBATCH --partition=stud
#SBATCH --qos=stud
#SBATCH --gpus=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=24G
#SBATCH --time=02:00:00
#SBATCH --output=slurm/logs/%x_%j.out
#SBATCH --error=slurm/logs/%x_%j.err

set -euo pipefail
source "$SLURM_SUBMIT_DIR/slurm/env.sh"

python -u analysis_wiki/subword_fasttext/src/run_approach.py
